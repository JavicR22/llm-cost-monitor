# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
APP_NAME="LLM Cost Monitor"

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev (docker-compose): postgresql+asyncpg://llmcost:llmcost@localhost:5432/llmcost
# Railway:  provided automatically as $DATABASE_URL
DATABASE_URL=postgresql+asyncpg://llmcost:llmcost@localhost:5432/llmcost

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev (docker-compose): redis://localhost:6379/0
# Railway: provided automatically as $REDIS_URL
REDIS_URL=redis://localhost:6379/0

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=

# ── JWT RS256 ─────────────────────────────────────────────────────────────────
# Generate:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# In Railway: paste as multiline env var (keep the header/footer lines)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ALGORITHM=RS256
JWT_EXPIRE_HOURS=24

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production: set to your Vercel URL
# CORS_ORIGINS=["https://your-app.vercel.app"]
CORS_ORIGINS=["http://localhost:3000"]

# ── Email notifications (optional) ───────────────────────────────────────────
# Get your key at: resend.com — leave empty to disable notifications
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=alerts@yourdomain.com

# ── Server (optional, Railway sets PORT automatically) ───────────────────────
WEB_CONCURRENCY=2
PORT=8000
